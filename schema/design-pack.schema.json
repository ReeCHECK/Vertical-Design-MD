{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vertical-design-md.dev/schema/design-pack.schema.json",
  "title": "Vertical Design Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema", "schema_version", "id", "name", "version", "summary", "domain",
    "risk_level", "density", "surfaces", "audiences", "locales",
    "accessibility_target", "required_documents", "coverage", "provenance"
  ],
  "properties": {
    "$schema": { "const": "../../schema/design-pack.schema.json" },
    "schema_version": { "const": "1.0" },
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "name": { "type": "string", "minLength": 3 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "summary": { "type": "string", "minLength": 30 },
    "domain": { "type": "string", "minLength": 2 },
    "risk_level": { "enum": ["low", "moderate", "high", "critical"] },
    "density": { "enum": ["comfortable", "balanced", "compact", "adaptive"] },
    "surfaces": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "enum": ["web", "desktop", "tablet", "mobile", "kiosk"] }
    },
    "audiences": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "minLength": 2 }
    },
    "locales": {
      "type": "array", "minItems": 1, "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z]{2}(?:-[A-Z]{2})?$" }
    },
    "accessibility_target": { "enum": ["WCAG 2.2 AA", "WCAG 2.2 AAA"] },
    "required_documents": {
      "type": "array", "minItems": 8, "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[A-Z][A-Z-]+\\.md$" }
    },
    "coverage": {
      "type": "object", "additionalProperties": false,
      "required": ["scenarios", "states"],
      "properties": {
        "scenarios": { "type": "array", "minItems": 2, "uniqueItems": true, "items": { "type": "string" } },
        "states": { "type": "array", "minItems": 6, "uniqueItems": true, "items": { "type": "string" } }
      }
    },
    "provenance": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["source_type", "title", "url", "reviewed_at", "confidence"],
        "properties": {
          "source_type": { "enum": ["primary", "research", "recommendation"] },
          "title": { "type": "string", "minLength": 3 },
          "url": { "type": "string", "format": "uri" },
          "reviewed_at": { "type": "string", "format": "date" },
          "confidence": { "enum": ["low", "medium", "high"] }
        }
      }
    }
  }
}
